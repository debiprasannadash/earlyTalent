<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Dashboard | Early Talent</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Hide scrollbar for clean look */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col hidden md:flex">
        <div class="h-20 flex items-center px-6 border-b border-gray-200">
            <i class="fa-solid fa-seedling text-indigo-600 text-2xl mr-2"></i>
            <span class="font-bold text-xl tracking-tight text-gray-900">Early<span class="text-indigo-600">Talent</span></span>
        </div>
        <div class="px-4 py-6 text-sm font-semibold text-gray-500 tracking-wider uppercase">Business Panel</div>
        <nav class="flex-1 px-4 space-y-2">
            <a href="#" class="flex items-center px-4 py-3 bg-indigo-50 text-indigo-700 rounded-xl font-medium">
                <i class="fa-solid fa-layer-group w-6"></i> Dashboard
            </a>
            <a href="#" class="flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-xl font-medium transition">
                <i class="fa-solid fa-list-check w-6"></i> My Tasks
            </a>
            <a href="#" class="flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-xl font-medium transition">
                <i class="fa-solid fa-users w-6"></i> Candidates
            </a>
            <a href="#" class="flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-xl font-medium transition">
                <i class="fa-solid fa-gear w-6"></i> Settings
            </a>
        </nav>
        <div class="p-4 border-t border-gray-200">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold">SM</div>
                <div>
                    <p class="text-sm font-bold text-gray-900">TechNova Inc.</p>
                    <p class="text-xs text-gray-500">Sarah Manager</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-y-auto">
        
        <!-- Top Header -->
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-8 sticky top-0 z-10">
            <h1 class="text-2xl font-bold text-gray-900">Task Management</h1>
            <div class="flex items-center gap-4">
                <button class="text-gray-400 hover:text-gray-600 text-xl"><i class="fa-regular fa-bell"></i></button>
                <button onclick="openModal('createTaskModal')" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-lg font-medium shadow-sm transition flex items-center gap-2">
                    <i class="fa-solid fa-plus"></i> Post New Task
                </button>
            </div>
        </header>

        <!-- Dashboard Body -->
        <div class="p-8">
            
            <!-- Quick Stats -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-gray-500 text-sm font-medium mb-1">Active Tasks</div>
                    <div class="text-3xl font-bold text-gray-900">4</div>
                </div>
                <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-gray-500 text-sm font-medium mb-1">Pending Applications</div>
                    <div class="text-3xl font-bold text-blue-600">12</div>
                </div>
                <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-gray-500 text-sm font-medium mb-1">Awaiting Review</div>
                    <div class="text-3xl font-bold text-orange-500">1</div>
                </div>
                <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-gray-500 text-sm font-medium mb-1">Completed & Awarded</div>
                    <div class="text-3xl font-bold text-green-600">8</div>
                </div>
            </div>

            <!-- Task List Table -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-200 flex justify-between items-center bg-gray-50">
                    <h2 class="text-lg font-bold text-gray-900">All Tasks</h2>
                    <div class="relative">
                        <i class="fa-solid fa-search absolute left-3 top-3 text-gray-400"></i>
                        <input type="text" placeholder="Search tasks..." class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-600 outline-none w-64">
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white border-b border-gray-200 text-sm text-gray-500">
                                <th class="px-6 py-4 font-medium">Task Name</th>
                                <th class="px-6 py-4 font-medium">Category</th>
                                <th class="px-6 py-4 font-medium">Status</th>
                                <th class="px-6 py-4 font-medium">Applicants/Assignee</th>
                                <th class="px-6 py-4 font-medium text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm divide-y divide-gray-200">
                            
                            <!-- Task 1: Looking for applicants -->
                            <tr class="hover:bg-gray-50 transition" id="task-row-1">
                                <td class="px-6 py-4 font-medium text-gray-900">Redesign Landing Page<br><span class="text-xs text-gray-500 font-normal">Posted 2 days ago</span></td>
                                <td class="px-6 py-4 text-gray-600">Web Design</td>
                                <td class="px-6 py-4"><span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-semibold">Open for Apps</span></td>
                                <td class="px-6 py-4 text-gray-600">5 Applicants</td>
                                <td class="px-6 py-4 text-right space-x-2">
                                    <button onclick="openModal('applicantsModal')" class="text-indigo-600 bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded text-xs font-medium transition">View Applicants</button>
                                    <button class="text-gray-400 hover:text-indigo-600"><i class="fa-solid fa-pen"></i></button>
                                    <button onclick="deleteTask(1)" class="text-gray-400 hover:text-red-600"><i class="fa-solid fa-trash"></i></button>
                                </td>
                            </tr>

                            <!-- Task 2: In Progress -->
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4 font-medium text-gray-900">Write 3 SEO Blog Posts<br><span class="text-xs text-gray-500 font-normal">Due in 4 days</span></td>
                                <td class="px-6 py-4 text-gray-600">Content Writing</td>
                                <td class="px-6 py-4"><span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs font-semibold">In Progress</span></td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-indigo-500 text-white flex items-center justify-center text-xs">JD</div>
                                        <span class="text-gray-600">Jane Doe</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right space-x-2">
                                    <button class="text-gray-400 hover:text-indigo-600"><i class="fa-solid fa-comment-dots text-lg"></i></button>
                                </td>
                            </tr>

                            <!-- Task 3: Submitted (Needs Review) -->
                            <tr class="hover:bg-gray-50 transition bg-orange-50/30">
                                <td class="px-6 py-4 font-medium text-gray-900">Design Social Media Template<br><span class="text-xs text-orange-500 font-medium">Action Required</span></td>
                                <td class="px-6 py-4 text-gray-600">Graphic Design</td>
                                <td class="px-6 py-4"><span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-semibold">Submitted</span></td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-green-500 text-white flex items-center justify-center text-xs">MS</div>
                                        <span class="text-gray-600">Mike Smith</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right space-x-2">
                                    <button onclick="openModal('reviewModal')" class="text-white bg-orange-500 hover:bg-orange-600 px-3 py-1.5 rounded text-xs font-medium transition shadow-sm">Review Work</button>
                                </td>
                            </tr>
                            
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- ========================================== -->
    <!-- MODALS (Hidden by default)                 -->
    <!-- ========================================== -->

    <!-- Modal Overlay Background -->
    <div id="modalOverlay" class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm hidden z-40 transition-opacity"></div>

    <!-- 1. Create/Post Task Modal -->
    <div id="createTaskModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white rounded-2xl shadow-2xl z-50 hidden flex-col max-h-[90vh]">
        <div class="flex justify-between items-center p-6 border-b border-gray-200">
            <h3 class="text-xl font-bold text-gray-900">Post a New Task</h3>
            <button onclick="closeModal('createTaskModal')" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <div class="p-6 overflow-y-auto">
            <form class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Task Title</label>
                    <input type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none" placeholder="e.g. Design a modern logo for my cafe">
                </div>
                <div class="grid grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                        <select class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none">
                            <option>Graphic Design</option>
                            <option>Web Design</option>
                            <option>Content Writing</option>
                            <option>Digital Marketing</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Deadline</label>
                        <input type="date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Task Description & Requirements</label>
                    <textarea rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none" placeholder="Explain what you need the student to do..."></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Reward Offered</label>
                    <div class="flex gap-4">
                        <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" checked class="rounded text-indigo-600"> 500 EXP Points</label>
                        <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" checked class="rounded text-indigo-600"> Verified Portfolio Certificate</label>
                    </div>
                </div>
            </form>
        </div>
        <div class="p-6 border-t border-gray-200 bg-gray-50 rounded-b-2xl flex justify-end gap-3">
            <button onclick="closeModal('createTaskModal')" class="px-5 py-2.5 text-gray-600 font-medium hover:bg-gray-200 rounded-lg transition">Cancel</button>
            <button onclick="alert('Task Posted Successfully!'); closeModal('createTaskModal');" class="px-5 py-2.5 bg-indigo-600 text-white font-medium hover:bg-indigo-700 rounded-lg transition shadow-sm">Publish Task</button>
        </div>
    </div>

    <!-- 2. View Applications & Assign Modal -->
    <div id="applicantsModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl bg-white rounded-2xl shadow-2xl z-50 hidden flex-col max-h-[90vh]">
        <div class="flex justify-between items-center p-6 border-b border-gray-200">
            <div>
                <h3 class="text-xl font-bold text-gray-900">Review Candidates</h3>
                <p class="text-sm text-gray-500">Task: Redesign Landing Page</p>
            </div>
            <button onclick="closeModal('applicantsModal')" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <div class="p-0 overflow-y-auto">
            <!-- Candidate 1 -->
            <div class="p-6 border-b border-gray-100 flex justify-between items-center hover:bg-gray-50">
                <div class="flex gap-4 items-center">
                    <img src="https://ui-avatars.com/api/?name=Alex+Johnson&background=6366f1&color=fff" class="w-12 h-12 rounded-full">
                    <div>
                        <h4 class="font-bold text-gray-900">Alex Johnson <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-0.5 rounded ml-2">Level 4 Designer</span></h4>
                        <p class="text-sm text-gray-500">"I have experience with Figma and would love to help you rebuild this layout!"</p>
                        <a href="#" class="text-indigo-600 text-xs font-semibold hover:underline">View Portfolio</a>
                    </div>
                </div>
                <button onclick="assignTask()" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-800 transition">Assign Task</button>
            </div>
            <!-- Candidate 2 -->
            <div class="p-6 border-b border-gray-100 flex justify-between items-center hover:bg-gray-50">
                <div class="flex gap-4 items-center">
                    <img src="https://ui-avatars.com/api/?name=Sam+Lee&background=10b981&color=fff" class="w-12 h-12 rounded-full">
                    <div>
                        <h4 class="font-bold text-gray-900">Sam Lee <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded ml-2">Level 2 Designer</span></h4>
                        <p class="text-sm text-gray-500">"I'm a fast learner and can start immediately."</p>
                        <a href="#" class="text-indigo-600 text-xs font-semibold hover:underline">View Portfolio</a>
                    </div>
                </div>
                <button onclick="assignTask()" class="bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition">Assign Task</button>
            </div>
        </div>
    </div>

    <!-- 3. Review Submission & Award Certificate Modal -->
    <div id="reviewModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white rounded-2xl shadow-2xl z-50 hidden flex-col max-h-[90vh]">
        <div class="flex justify-between items-center p-6 border-b border-gray-200 bg-orange-50 rounded-t-2xl">
            <div>
                <h3 class="text-xl font-bold text-gray-900">Review Student Submission</h3>
                <p class="text-sm text-orange-600 font-medium">Task: Design Social Media Template</p>
            </div>
            <button onclick="closeModal('reviewModal')" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <div class="p-6">
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 mb-6">
                <div class="flex items-center gap-3 mb-3">
                    <img src="https://ui-avatars.com/api/?name=Mike+Smith&background=10b981&color=fff" class="w-8 h-8 rounded-full">
                    <span class="font-bold text-sm text-gray-900">Mike Smith (Assignee)</span>
                </div>
                <p class="text-sm text-gray-700 mb-4">"Hi Sarah! Attached are the 3 templates requested. I made sure to use your brand hex codes. Let me know if you need any revisions!"</p>
                <div class="flex gap-3">
                    <div class="border border-gray-300 bg-white px-3 py-2 rounded-lg flex items-center gap-2 text-sm w-max cursor-pointer hover:bg-gray-50">
                        <i class="fa-solid fa-file-image text-blue-500"></i> template_1.png
                    </div>
                    <div class="border border-gray-300 bg-white px-3 py-2 rounded-lg flex items-center gap-2 text-sm w-max cursor-pointer hover:bg-gray-50">
                        <i class="fa-brands fa-figma text-pink-500"></i> figma_source_file
                    </div>
                </div>
            </div>

            <!-- Grading / Rewarding -->
            <h4 class="font-bold text-gray-900 mb-3">Rate & Reward</h4>
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-600">Quality of Work</span>
                    <div class="text-yellow-400 text-lg cursor-pointer">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i>
                    </div>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-600">Communication & Timeliness</span>
                    <div class="text-yellow-400 text-lg cursor-pointer">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                    </div>
                </div>
                <textarea rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none text-sm" placeholder="Leave a review for Mike's public portfolio..."></textarea>
            </div>
        </div>
        <div class="p-6 border-t border-gray-200 bg-gray-50 rounded-b-2xl flex justify-between items-center">
            <button class="text-red-600 text-sm font-medium hover:underline">Request Revision</button>
            <div class="flex gap-3">
                <button onclick="closeModal('reviewModal')" class="px-5 py-2.5 text-gray-600 font-medium hover:bg-gray-200 rounded-lg transition">Cancel</button>
                <button onclick="approveAndReward()" class="px-5 py-2.5 bg-green-600 text-white font-medium hover:bg-green-700 rounded-lg transition shadow-sm flex items-center gap-2">
                    <i class="fa-solid fa-trophy"></i> Approve & Award Certificate
                </button>
            </div>
        </div>
    </div>

    <!-- Javascript for Modal Interactions -->
    <script>
        const overlay = document.getElementById('modalOverlay');

        function openModal(modalId) {
            overlay.classList.remove('hidden');
            document.getElementById(modalId).classList.remove('hidden');
            document.getElementById(modalId).classList.add('flex');
        }

        function closeModal(modalId) {
            overlay.classList.add('hidden');
            document.getElementById(modalId).classList.add('hidden');
            document.getElementById(modalId).classList.remove('flex');
        }

        // Close modals when clicking outside
        overlay.addEventListener('click', () => {
            const modals = ['createTaskModal', 'applicantsModal', 'reviewModal'];
            modals.forEach(id => closeModal(id));
        });

        // Mock Action: Delete Task
        function deleteTask(id) {
            if(confirm("Are you sure you want to delete this task?")) {
                document.getElementById('task-row-' + id).style.display = 'none';
                alert("Task deleted.");
            }
        }

        // Mock Action: Assign Task
        function assignTask() {
            closeModal('applicantsModal');
            alert("Success! The candidate has been assigned. The task will now move to 'In Progress'.");
        }

        // Mock Action: Approve & Reward
        function approveAndReward() {
            closeModal('reviewModal');
            alert("🎉 Task Completed! The student has been awarded EXP points and a Verified Portfolio Certificate.");
        }
    </script>
</body>
</html>
