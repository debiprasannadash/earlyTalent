<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Registration | Early Talent</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Custom scrollbar for the right panel */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>
<body class="bg-white flex min-h-screen">

    <!-- LEFT PANEL: Branding & Value Proposition (Hidden on Mobile) -->
    <div class="hidden lg:flex lg:w-5/12 bg-gradient-to-br from-indigo-700 via-indigo-600 to-blue-600 text-white flex-col justify-between p-12 relative overflow-hidden">
        
        <!-- Abstract Background Shapes -->
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden opacity-10 pointer-events-none">
            <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-white blur-3xl"></div>
            <div class="absolute bottom-0 right-0 w-80 h-80 rounded-full bg-white blur-3xl"></div>
        </div>

        <!-- Logo -->
        <div class="relative z-10">
            <a href="index.html" class="flex items-center gap-2 hover:opacity-90 transition w-max">
                <i class="fa-solid fa-seedling text-white text-3xl"></i>
                <span class="font-bold text-3xl tracking-tight text-white">EarlyTalent</span>
            </a>
        </div>

        <!-- Copy/Value Prop -->
        <div class="relative z-10 mt-12 mb-auto">
            <h1 class="text-4xl font-bold leading-tight mb-6">
                Fresh ideas.<br>Emerging talent.<br>Zero hassle.
            </h1>
            <p class="text-indigo-100 text-lg mb-8 max-w-md">
                Register your business to post micro-tasks, collaborate with ambitious students, and get work done while building your future talent pipeline.
            </p>

            <ul class="space-y-4">
                <li class="flex items-center gap-3 text-indigo-50">
                    <div class="w-6 h-6 rounded-full bg-indigo-500 flex items-center justify-center text-sm"><i class="fa-solid fa-check"></i></div>
                    Cost-effective digital solutions
                </li>
                <li class="flex items-center gap-3 text-indigo-50">
                    <div class="w-6 h-6 rounded-full bg-indigo-500 flex items-center justify-center text-sm"><i class="fa-solid fa-check"></i></div>
                    Scout candidates before hiring
                </li>
                <li class="flex items-center gap-3 text-indigo-50">
                    <div class="w-6 h-6 rounded-full bg-indigo-500 flex items-center justify-center text-sm"><i class="fa-solid fa-check"></i></div>
                    Support student education via real experience
                </li>
            </ul>
        </div>

        <!-- Testimonial -->
        <div class="relative z-10 bg-indigo-800/40 p-6 rounded-2xl border border-indigo-500/30 backdrop-blur-sm">
            <div class="flex text-yellow-400 text-sm mb-3">
                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
            </div>
            <p class="text-sm text-indigo-50 italic mb-4">"Early Talent allowed us to completely redesign our cafe's menus and social media. The students were professional, fast, and highly creative!"</p>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-white text-indigo-600 flex items-center justify-center font-bold text-sm">MR</div>
                <div>
                    <p class="text-sm font-bold">Mark R.</p>
                    <p class="text-xs text-indigo-200">Owner, Daily Grind Cafe</p>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL: Registration Form -->
    <div class="w-full lg:w-7/12 flex flex-col items-center justify-center p-8 sm:p-12 lg:p-16 h-screen overflow-y-auto">
        <div class="w-full max-w-xl">
            
            <!-- Mobile Logo (Hidden on Desktop) -->
            <div class="lg:hidden flex items-center gap-2 mb-8">
                <i class="fa-solid fa-seedling text-indigo-600 text-3xl"></i>
                <span class="font-bold text-3xl tracking-tight text-gray-900">Early<span class="text-indigo-600">Talent</span></span>
            </div>

            <!-- Header -->
            <h2 class="text-3xl font-bold text-gray-900 mb-2">Register your Organization</h2>
            <p class="text-gray-500 mb-8">Already have a business account? <a href="login.html" class="text-indigo-600 font-semibold hover:underline">Log in here</a>.</p>

            <!-- Form -->
            <form id="businessRegForm" onsubmit="handleRegistration(event)" class="space-y-6">
                
                <!-- Section 1: Company Details -->
                <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 space-y-4">
                    <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider border-b border-gray-200 pb-2 mb-4">1. Organization Details</h3>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Company Name *</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-building text-gray-400"></i></div>
                            <input type="text" required class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition" placeholder="e.g. TechNova Inc.">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Industry *</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-industry text-gray-400"></i></div>
                                <select required class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition appearance-none bg-white">
                                    <option value="" disabled selected>Select Industry</option>
                                    <option>Technology / Software</option>
                                    <option>Retail / E-commerce</option>
                                    <option>Food & Beverage</option>
                                    <option>Marketing / Agency</option>
                                    <option>Healthcare / Wellness</option>
                                    <option>Other</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Company Size</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-users text-gray-400"></i></div>
                                <select class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition appearance-none bg-white">
                                    <option>1 - 10 employees (Startup)</option>
                                    <option>11 - 50 employees</option>
                                    <option>51 - 200 employees</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Website URL (Optional)</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-globe text-gray-400"></i></div>
                            <input type="url" class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition" placeholder="https://www.yourcompany.com">
                        </div>
                    </div>
                </div>

                <!-- Section 2: Contact Person -->
                <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 space-y-4">
                    <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider border-b border-gray-200 pb-2 mb-4">2. Account Administrator</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
                            <input type="text" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition" placeholder="Sarah">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
                            <input type="text" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition" placeholder="Connor">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Work Email *</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-regular fa-envelope text-gray-400"></i></div>
                            <input type="email" required class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition" placeholder="sarah@technova.com">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password *</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-lock text-gray-400"></i></div>
                            <input type="password" id="password" required class="w-full pl-10 pr-10 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 outline-none transition" placeholder="Create a secure password">
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer" onclick="togglePassword()">
                                <i id="eye-icon" class="fa-regular fa-eye text-gray-400 hover:text-gray-600"></i>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Must be at least 8 characters.</p>
                    </div>
                </div>

                <!-- Terms and Submit -->
                <div class="pt-2">
                    <label class="flex items-start gap-3 mb-6 cursor-pointer group">
                        <input type="checkbox" required class="mt-1 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 cursor-pointer">
                        <span class="text-sm text-gray-600 group-hover:text-gray-900 transition">
                            I agree to the <a href="#" class="text-indigo-600 font-medium hover:underline">Terms of Service</a> and acknowledge that student work is provided for experiential learning purposes.
                        </span>
                    </label>

                    <button type="submit" class="w-full bg-indigo-600 text-white font-bold text-lg py-3.5 rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                        Create Organization Account <i class="fa-solid fa-arrow-right ml-2"></i>
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        // Toggle Password Visibility
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const eyeIcon = document.getElementById('eye-icon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.classList.remove('fa-eye');
                eyeIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                eyeIcon.classList.remove('fa-eye-slash');
                eyeIcon.classList.add('fa-eye');
            }
        }

        // Handle Form Submission Mockup
        function handleRegistration(event) {
            event.preventDefault(); // Prevent page reload
            
            // In a real app, this is where you send the data to your backend database.
            // For now, we simulate success and redirect to the dashboard.
            
            alert("Registration Successful! Welcome to Early Talent. Redirecting you to your business dashboard...");
            
            // Redirect to the dashboard page we created earlier
            window.location.href = "business-dashboard.html";
        }
    </script>
</body>
</html>
